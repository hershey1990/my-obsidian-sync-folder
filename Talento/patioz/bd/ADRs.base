filters:
  and:
    - file.inFolder("Talento/patioz/adr")
    - file.ext == "md"
    - file.name != "00-index"
    - file.name != "plantilla"
views:
  - type: table
    name: ADRs
    order:
      - file.name
      - decision
      - estado
      - sync_status.backend
      - sync_status.frontend
    sort:
      - property: file.name
        direction: ASC
    limit: 50
