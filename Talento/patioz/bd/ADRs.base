filters:
  and:
    - file.inFolder("Talento/patioz/adr")
    - file.ext == "md"
    - file.name != "00-index"
    - file.name != "plantilla"
    - file.name != "README"
views:
  - type: table
    name: ADRs
    order:
      - file.name
      - decision
      - proyecto
      - estado
      - implementado
    sort:
      - property: file.name
        direction: ASC
    limit: 50
