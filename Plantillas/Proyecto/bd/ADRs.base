filters:
  and:
    - file.inFolder("{{PATH}}/adr")
    - file.ext == "md"
    - file.name != "00-index"
    - file.name != "plantilla"
views:
  - type: table
    name: ADRs
    order:
      - file.name
      - decision
      - proyecto
      - estado
      - sync_backend
      - sync_frontend
    sort:
      - property: file.name
        direction: ASC
    limit: 50
